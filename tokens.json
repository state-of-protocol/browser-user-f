{
  "_meta": {
    "schemaVersion": "1.0.0",
    "source": "DESIGN.md",
    "purpose": "Single source of truth untuk design tokens. Fail ini di-fetch oleh /js/token-loader.js dan di-inject sebagai CSS custom properties pada :root. JANGAN hardcode hex/px terus dalam style.css — rujuk token ini sahaja.",
    "brand": "Browser Use",
    "url": "https://browser-use.com/",
    "lastUpdated": "2026-06-29"
  },

  "font": {
    "family": {
      "primary": "Geist",
      "stack": "Geist, Geist Fallback, -apple-system, BlinkMacSystemFont, sans-serif"
    },
    "size": {
      "base": "16px",
      "xs": "9px",
      "sm": "10px",
      "md": "12px",
      "lg": "13px",
      "xl": "14px",
      "2xl": "16px",
      "3xl": "48px",
      "4xl": "60px"
    },
    "weight": {
      "base": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeight": {
      "base": "24px",
      "tight": "1.1",
      "normal": "1.5"
    }
  },

  "color": {
    "text": {
      "primary": "#71717a",
      "secondary": "#fafafa",
      "tertiary": "#ffffff",
      "inverse": "#52525b"
    },
    "surface": {
      "base": "#000000",
      "muted": "#fe750e",
      "raised": "#09090b",
      "strong": "#3f3f46"
    },
    "border": {
      "default": "#27272a"
    },
    "state": {
      "focusRing": "#fe750e",
      "errorText": "#ef4444",
      "errorBorder": "#7f1d1d",
      "successText": "#22c55e"
    }
  },

  "space": {
    "1": "6px",
    "2": "8px",
    "3": "14px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "32px",
    "8": "48px"
  },

  "radius": {
    "xs": "4px",
    "sm": "6px",
    "md": "8px",
    "lg": "12px",
    "full": "9999px"
  },

  "motion": {
    "duration": {
      "instant": "150ms",
      "fast": "200ms",
      "normal": "300ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.4, 0, 0.2, 1)"
    }
  },

  "breakpoint": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px"
  },

  "zIndex": {
    "base": 1,
    "dropdown": 100,
    "header": 200,
    "modal": 300,
    "toast": 400
  }
}
